rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default: only authenticated users
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Public readable collections
    match /blogs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /projects/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /experiences/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /stats/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /speaking_engagements/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /publications/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /contact_messages/{document} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    match /dummy_activity/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}